{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SceneWeaver",
  "version": "0.1.0",
  "identifier": "com.sceneweaver.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SceneWeaver",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "resources": {
      "target/release/WebView2Loader.dll": "WebView2Loader.dll",
      "vendor/onnxruntime/onnxruntime.dll": "onnxruntime.dll"
    }
  },
  "plugins": {}
}
